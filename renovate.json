{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>BlindfoldedSurgery/renovate-config"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "terraform"
      ],
      "rangeStrategy": "replace"
    },
    {
      "matchDepNames": [
        "github"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "semanticCommitType": "feat!"
    },
    {
      "matchDepNames": [
        "github"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "semanticCommitType": "feat"
    },
    {
      "matchDepNames": [
        "terraform"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "semanticCommitType": "feat"
    }
  ]
}
